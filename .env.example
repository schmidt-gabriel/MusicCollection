# Copy this file to .env and fill in the values. Loaded by docker-compose.yml.

# ---------- API (backend) ----------
# Mongo runs inside the compose stack; the database is created on first write.
MONGODB_DATABASE=music
# Auth0 API identifier and tenant the backend validates access tokens against.
AUTH0_AUDIENCE=https://music-collection-api
AUTH0_DOMAIN=your-tenant.us.auth0.com
# External API credentials, held server-side and used by the /spotify and
# /discogs proxies (never sent to the browser). Optional: leave empty to disable
# those lookups.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
DISCOGS_TOKEN=

# ---------- Web UI (frontend) ----------
# Host the browser uses to reach the API (the compose api publishes port 3000).
REACT_APP_API_DOMAIN=localhost:3000
# Auth0 SPA application (needed only when REACT_APP_MOCK is empty).
REACT_APP_AUTH0_DOMAIN=your-tenant.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your-spa-client-id
# Audience host; the code prefixes https:// (must match AUTH0_AUDIENCE above).
REACT_APP_AUDIENCE=music-collection-api
# Set to 1 to run the UI on fixture data, skipping Auth0 and the API entirely.
REACT_APP_MOCK=

# ---------- Host ports (override only if one is already taken) ----------
# WEB_PORT=5173
# API_PORT=3000
# MONGO_PORT=27017
